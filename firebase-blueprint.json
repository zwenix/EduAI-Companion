{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with roles (teacher, learner, parent) and settings.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["teacher", "learner", "parent"] },
        "school": { "type": "string" },
        "jobTitle": { "type": "string" },
        "phone": { "type": "string" },
        "photoUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "role", "createdAt"]
    },
    "Student": {
      "title": "Student",
      "description": "Learner records managed by teachers.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "grade": { "type": "string" },
        "email": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "teacherId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "grade", "email", "status", "teacherId", "createdAt"]
    },
    "Class": {
      "title": "Class",
      "description": "class records.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "subject": { "type": "string" },
        "teacherId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "subject", "teacherId", "createdAt"]
    },
    "StudyGroup": {
      "title": "Study Group",
      "description": "Study groups created by teachers.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "teacherId": { "type": "string" },
        "members": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "description", "teacherId", "members", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notifications.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "message", "read", "userId", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "Chat message for Messenger.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "senderName", "text", "createdAt"]
    },
    "CreatedContent": {
      "title": "Created Content",
      "description": "Content archive containing lessons, videos, and visuals.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subject": { "type": "string" },
        "grade": { "type": "string" },
        "contentType": { "type": "string" },
        "content": { "type": "string" },
        "teacherId": { "type": "string" },
        "isSystem": { "type": "boolean" },
        "memo": { "type": "string" },
        "rubric": { "type": "string" },
        "imagePrompt": { "type": "string" },
        "previewUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "subject", "grade", "contentType", "content", "teacherId", "isSystem", "createdAt"]
    },
    "AiChatSession": {
      "title": "AI Chat Session",
      "description": "AITutor local messages backup.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "messages": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "messages", "updatedAt"]
    },
    "Lesson": {
      "title": "Lesson",
      "description": "User created classroom lessons structured by subject, topic and phase.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "topic": { "type": "string" },
        "date": { "type": "string" },
        "notes": { "type": "string" },
        "resources": { "type": "string" },
        "phase": { "type": "string" },
        "subject": { "type": "string" },
        "userEmail": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["title", "topic", "date", "notes", "resources", "phase", "subject", "userEmail"]
    },
    "Illustration": {
      "title": "Illustration",
      "description": "Cached illustration files mapped to teacher visual prompts.",
      "type": "object",
      "properties": {
        "prompt": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "teacherId": { "type": "string" }
      },
      "required": ["prompt", "imageUrl", "createdAt"]
    },
    "GeneratedVideo": {
      "title": "Generated Video",
      "description": "Cached video files generated using the OmniHuman API mapped to teacher prompts.",
      "type": "object",
      "properties": {
        "prompt": { "type": "string" },
        "videoUrl": { "type": "string" },
        "model": { "type": "string" },
        "seed": { "type": "number" },
        "fps": { "type": "number" },
        "teacherId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["prompt", "videoUrl", "teacherId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Profiles."
    },
    "/students/{studentId}": {
      "schema": "Student",
      "description": "Learners managed by a teacher"
    },
    "/classes/{classId}": {
      "schema": "Class",
      "description": "Classes."
    },
    "/study_groups/{groupId}": {
      "schema": "StudyGroup",
      "description": "Study groups."
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Notifications."
    },
    "/communicator_messages/{messageId}": {
      "schema": "Message",
      "description": "Messenger messages."
    },
    "/ai_tutor_sessions/{userId}": {
      "schema": "AiChatSession",
      "description": "Tutor sessions."
    },
    "/ai_floating_sessions/{userId}": {
      "schema": "AiChatSession",
      "description": "Floating tutor sessions."
    },
    "/created_content/{contentId}": {
      "schema": "CreatedContent",
      "description": "Archived generated content."
    },
    "/lessons/{lessonId}": {
      "schema": "Lesson",
      "description": "User created classroom lessons."
    },
    "/illustrations/{illustrationId}": {
      "schema": "Illustration",
      "description": "Cached illustrations and diagrams."
    },
    "/assignments/{assignmentId}": {
      "schema": "Assignment",
      "description": "Teacher's generated assessment or worksheet assignments"
    },
    "/submissions/{submissionId}": {
      "schema": "Submission",
      "description": "Student's submissions for grading and results history"
    },
    "/omnihuman_videos/{videoId}": {
      "schema": "GeneratedVideo",
      "description": "Cached video files generated using the OmniHuman API."
    }
  }
}
