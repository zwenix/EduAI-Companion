{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with roles (teacher, learner, parent) and settings.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["teacher", "learner", "parent"] },
        "school": { "type": "string" },
        "jobTitle": { "type": "string" },
        "phone": { "type": "string" },
        "photoUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "role", "createdAt"]
    },
    "Student": {
      "title": "Student",
      "description": "Learner records managed by teachers.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "grade": { "type": "string" },
        "email": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "teacherId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "grade", "email", "status", "teacherId", "createdAt"]
    },
    "Class": {
      "title": "Class",
      "description": "class records.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "subject": { "type": "string" },
        "teacherId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "subject", "teacherId", "createdAt"]
    },
    "StudyGroup": {
      "title": "Study Group",
      "description": "Study groups created by teachers.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "teacherId": { "type": "string" },
        "members": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "description", "teacherId", "members", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notifications.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "message", "read", "userId", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "Chat message for Messenger.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "senderName", "text", "createdAt"]
    },
    "AiChatSession": {
      "title": "AI Chat Session",
      "description": "AITutor local messages backup.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "messages": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "messages", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Profiles."
    },
    "/students/{studentId}": {
      "schema": "Student",
      "description": "Learners managed by a teacher"
    },
    "/classes/{classId}": {
      "schema": "Class",
      "description": "Classes."
    },
    "/study_groups/{groupId}": {
      "schema": "StudyGroup",
      "description": "Study groups."
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Notifications."
    },
    "/communicator_messages/{messageId}": {
      "schema": "Message",
      "description": "Messenger messages."
    },
    "/ai_tutor_sessions/{userId}": {
      "schema": "AiChatSession",
      "description": "Tutor sessions."
    }
  }
}
