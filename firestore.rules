rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { allow read, write: if false; }

    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    function isValidUser(data) {
      return data.keys().size() >= 4
        && data.keys().size() <= 9
        && data.name is string && data.name.size() <= 100
        && data.email is string && data.email.size() <= 150
        && data.role is string && data.role in ['teacher', 'learner', 'parent']
        && data.createdAt is timestamp
        && (!('school' in data) || data.school == null || (data.school is string && data.school.size() <= 150))
        && (!('jobTitle' in data) || data.jobTitle == null || (data.jobTitle is string && data.jobTitle.size() <= 100))
        && (!('phone' in data) || data.phone == null || (data.phone is string && data.phone.size() <= 20))
        && (!('photoUrl' in data) || data.photoUrl == null || (data.photoUrl is string && data.photoUrl.size() <= 1000))
        && (!('updatedAt' in data) || data.updatedAt == null || data.updatedAt is timestamp);
    }
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming())
                     && incoming().createdAt == existing().createdAt
                     && incoming().updatedAt == request.time
                     && (
                        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'school', 'jobTitle', 'phone', 'photoUrl', 'updatedAt'])
                     );
    }

    function isValidStudent(data) {
      return data.name is string && data.name.size() <= 100
        && data.grade is string && data.grade.size() <= 50
        && data.email is string && data.email.size() <= 150
        && data.status is string && data.status in ['Active', 'Inactive']
        && (!('teacherId' in data) || data.teacherId == null || (data.teacherId is string && data.teacherId.size() <= 128))
        && (!('createdAt' in data) || data.createdAt == null || data.createdAt is timestamp)
        && (!('updatedAt' in data) || data.updatedAt == null || data.updatedAt is timestamp)
        && (!('parentId' in data) || data.parentId == null || (data.parentId is string && data.parentId.size() <= 128))
        && (!('parentName' in data) || data.parentName == null || (data.parentName is string && data.parentName.size() <= 100))
        && (!('parentEmail' in data) || data.parentEmail == null || (data.parentEmail is string && data.parentEmail.size() <= 150))
        && (!('parentPhone' in data) || data.parentPhone == null || (data.parentPhone is string && data.parentPhone.size() <= 30))
        && (!('streak' in data) || data.streak is int)
        && (!('lastActiveDate' in data) || data.lastActiveDate is string)
        && (!('subjects' in data) || data.subjects is list)
        && (!('idp' in data) || data.idp is map);
    }
    match /students/{studentId} {
      allow get: if isSignedIn() && isValidId(studentId) && (
        existing().teacherId == request.auth.uid || 
        existing().email == request.auth.token.email ||
        ('parentEmail' in existing() && existing().parentEmail == request.auth.token.email)
      );
      allow list: if isSignedIn() && (
        resource.data.teacherId == request.auth.uid || 
        resource.data.email == request.auth.token.email ||
        ('parentEmail' in resource.data && resource.data.parentEmail == request.auth.token.email)
      );
      allow create: if isSignedIn() && isValidId(studentId) && isValidStudent(incoming()) && (
        incoming().teacherId == request.auth.uid || 
        incoming().email == request.auth.token.email
      );
      allow update: if isSignedIn() && isValidId(studentId) && isValidStudent(incoming()) && (
        // Case 1: The teacher is updating
        (existing().teacherId == request.auth.uid && incoming().teacherId == existing().teacherId &&
         incoming().diff(existing()).affectedKeys().hasOnly(['name', 'grade', 'email', 'status', 'updatedAt', 'parentId', 'subjects', 'idp', 'lastActiveDate', 'streak', 'parentName', 'parentEmail', 'parentPhone'])) ||
        // Case 2: The student is self-updating progress, streak, or IDPs
        (existing().email == request.auth.token.email &&
         incoming().diff(existing()).affectedKeys().hasOnly(['lastActiveDate', 'streak', 'idp', 'updatedAt', 'subjects']))
      );
      allow delete: if isSignedIn() && isValidId(studentId) && existing().teacherId == request.auth.uid;
    }

    function isValidClass(data) {
      return data.keys().size() >= 4 && data.keys().size() <= 5
        && data.name is string && data.name.size() <= 100
        && data.subject is string && data.subject.size() <= 100
        && data.teacherId is string && data.teacherId == request.auth.uid
        && data.createdAt is timestamp;
    }
    match /classes/{classId} {
      allow get: if isSignedIn() && isValidId(classId) && existing().teacherId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.teacherId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(classId) && isValidClass(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && isValidId(classId) && existing().teacherId == request.auth.uid && isValidClass(incoming())
                     && incoming().teacherId == existing().teacherId
                     && incoming().createdAt == existing().createdAt
                     && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'subject']);
      allow delete: if isSignedIn() && isValidId(classId) && existing().teacherId == request.auth.uid;
    }

    function isValidStudyGroup(data) {
      return data.keys().size() >= 5 && data.keys().size() <= 6
        && data.name is string && data.name.size() <= 100
        && data.description is string && data.description.size() <= 1000
        && data.teacherId is string && data.teacherId == request.auth.uid
        && data.members is list && data.members.size() <= 50 && (data.members.size() == 0 || data.members[0] is string)
        && data.createdAt is timestamp;
    }
    match /study_groups/{groupId} {
      allow get: if isSignedIn() && isValidId(groupId) && existing().teacherId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.teacherId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(groupId) && isValidStudyGroup(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && isValidId(groupId) && existing().teacherId == request.auth.uid && isValidStudyGroup(incoming())
                     && incoming().teacherId == existing().teacherId
                     && incoming().createdAt == existing().createdAt
                     && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'members']);
      allow delete: if isSignedIn() && isValidId(groupId) && existing().teacherId == request.auth.uid;
    }

    function isValidNotification(data) {
      return data.keys().size() >= 5 && data.keys().size() <= 6
        && data.title is string && data.title.size() <= 150
        && data.message is string && data.message.size() <= 1000
        && data.read is bool
        && data.userId is string && data.userId.size() <= 128
        && data.createdAt is timestamp;
    }
    match /notifications/{notificationId} {
      allow get: if isSignedIn() && isValidId(notificationId) && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(notificationId) && isValidNotification(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && isValidId(notificationId) && existing().userId == request.auth.uid && isValidNotification(incoming())
                     && incoming().userId == existing().userId
                     && incoming().createdAt == existing().createdAt
                     && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isSignedIn() && isValidId(notificationId) && existing().userId == request.auth.uid;
    }

    function isValidMessage(data) {
      return data.keys().size() >= 4 && data.keys().size() <= 5
        && data.senderId is string && data.senderId == request.auth.uid
        && data.senderName is string && data.senderName.size() <= 100
        && data.text is string && data.text.size() <= 2000
        && data.createdAt is timestamp;
    }
    match /communicator_messages/{messageId} {
      allow get: if isSignedIn() && isValidId(messageId);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(messageId) && isValidMessage(incoming()) && incoming().createdAt == request.time;
    }

    function isValidAiSession(data) {
      return data.keys().size() >= 3 && data.keys().size() <= 4
        && data.userId is string && data.userId == request.auth.uid
        && data.messages is string && data.messages.size() <= 500000 
        && data.updatedAt is timestamp;
    }
    match /ai_tutor_sessions/{userId} {
      allow get: if isSignedIn() && userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && userId == request.auth.uid && isValidAiSession(incoming()) && incoming().updatedAt == request.time;
      allow update: if isSignedIn() && userId == request.auth.uid && isValidAiSession(incoming()) && incoming().updatedAt == request.time
                     && incoming().userId == existing().userId
                     && incoming().diff(existing()).affectedKeys().hasOnly(['messages', 'updatedAt']);
    }

    function isValidCreatedContent(data) {
      return data.keys().size() >= 8 && data.keys().size() <= 13
        && data.title is string && data.title.size() <= 200
        && data.subject is string && data.subject.size() <= 100
        && data.grade is string && data.grade.size() <= 50
        && data.contentType is string && data.contentType.size() <= 50
        && data.content is string && data.content.size() <= 500000
        && data.teacherId is string && data.teacherId == request.auth.uid
        && data.isSystem is bool
        && data.createdAt is timestamp
        && (!('memo' in data) || data.memo == null || (data.memo is string && data.memo.size() <= 50000))
        && (!('rubric' in data) || data.rubric == null || (data.rubric is string && data.rubric.size() <= 100000))
        && (!('imagePrompt' in data) || data.imagePrompt == null || (data.imagePrompt is string && data.imagePrompt.size() <= 5000))
        && (!('previewUrl' in data) || data.previewUrl == null || (data.previewUrl is string && data.previewUrl.size() <= 2000))
        && (!('updatedAt' in data) || data.updatedAt == null || data.updatedAt is timestamp);
    }
    match /created_content/{contentId} {
      allow get: if isSignedIn() && isValidId(contentId) && existing().teacherId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.teacherId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(contentId) && isValidCreatedContent(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && isValidId(contentId) && existing().teacherId == request.auth.uid && isValidCreatedContent(incoming())
                     && incoming().teacherId == existing().teacherId
                     && incoming().createdAt == existing().createdAt
                     && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'subject', 'grade', 'contentType', 'content', 'isSystem', 'memo', 'rubric', 'imagePrompt', 'previewUrl', 'updatedAt']);
      allow delete: if isSignedIn() && isValidId(contentId) && existing().teacherId == request.auth.uid;
    }

  }
}
